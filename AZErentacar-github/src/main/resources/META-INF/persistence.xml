<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="rentacarPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <class>com.rentacar.entity.Kullanici</class>
        <class>com.rentacar.entity.Arac</class>
        <class>com.rentacar.entity.Rezervasyon</class>
        <class>com.rentacar.entity.KiralamaIslemi</class>
        <class>com.rentacar.entity.Odeme</class>
        <class>com.rentacar.entity.BakimKayit</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/rentacar"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="130477"/>

            <property name="eclipselink.ddl-generation" value="create-or-extend-tables"/>
            <property name="eclipselink.logging.level" value="FINE"/>
        </properties>

    </persistence-unit>
</persistence>
